# AWS Credentials
# Get these from AWS Console → Security Credentials → Access Keys
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY_HERE
AWS_REGION=ap-south-1

# S3 Bucket Names (your actual bucket names without s3://)
S3_RAW_BUCKET=your-raw-bucket-name
S3_DELTA_BUCKET=your-delta-bucket-name

# Kinesis Stream
KINESIS_STREAM_NAME=log-stream

# Databricks (for local testing)
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your_databricks_token_here
