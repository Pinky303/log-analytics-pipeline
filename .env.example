# AWS Credentials (use IAM roles in production — never hardcode keys)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# S3 Bucket Names
S3_RAW_BUCKET=your-bucket-raw
S3_DELTA_BUCKET=your-bucket-delta

# Kinesis
KINESIS_STREAM_NAME=log-stream

# Databricks (for local testing)
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your_token_here
