{
  "name": "log_analytics_pipeline",
  "description": "End-to-end log analytics pipeline: Bronze → Silver → Gold",
  "schedule": {
    "quartz_cron_expression": "0 0 * * * ?",
    "timezone_id": "UTC",
    "pause_status": "UNPAUSED"
  },
  "email_notifications": {
    "on_failure": ["your-email@example.com"],
    "on_success": [],
    "no_alert_for_skipped_runs": true
  },
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "bronze_ingestion",
      "description": "Ingest raw logs from S3 into Bronze Delta table",
      "spark_python_task": {
        "python_file": "/Workspace/log-analytics-pipeline/transformations/01_bronze_ingestion.py"
      },
      "new_cluster": {
        "spark_version": "13.3.x-scala2.12",
        "node_type_id": "i3.xlarge",
        "num_workers": 2,
        "spark_conf": {
          "spark.sql.adaptive.enabled": "true",
          "spark.sql.adaptive.coalescePartitions.enabled": "true",
          "spark.databricks.delta.preview.enabled": "true"
        },
        "aws_attributes": {
          "instance_profile_arn": "arn:aws:iam::YOUR_ACCOUNT_ID:instance-profile/databricks-s3-role",
          "availability": "ON_DEMAND"
        }
      },
      "libraries": [
        {"pypi": {"package": "boto3"}},
        {"pypi": {"package": "delta-spark==2.4.0"}}
      ],
      "timeout_seconds": 1800,
      "max_retries": 2,
      "min_retry_interval_millis": 60000
    },
    {
      "task_key": "silver_cleaning",
      "description": "Clean and validate Bronze → Silver",
      "depends_on": [{"task_key": "bronze_ingestion"}],
      "spark_python_task": {
        "python_file": "/Workspace/log-analytics-pipeline/transformations/02_silver_cleaning.py"
      },
      "new_cluster": {
        "spark_version": "13.3.x-scala2.12",
        "node_type_id": "i3.xlarge",
        "num_workers": 2,
        "spark_conf": {
          "spark.sql.adaptive.enabled": "true",
          "spark.sql.shuffle.partitions": "100"
        },
        "aws_attributes": {
          "instance_profile_arn": "arn:aws:iam::YOUR_ACCOUNT_ID:instance-profile/databricks-s3-role",
          "availability": "ON_DEMAND"
        }
      },
      "libraries": [
        {"pypi": {"package": "delta-spark==2.4.0"}}
      ],
      "timeout_seconds": 1800,
      "max_retries": 1
    },
    {
      "task_key": "gold_aggregations",
      "description": "Compute KPIs and session summaries → Gold",
      "depends_on": [{"task_key": "silver_cleaning"}],
      "spark_python_task": {
        "python_file": "/Workspace/log-analytics-pipeline/transformations/03_gold_aggregations.py"
      },
      "new_cluster": {
        "spark_version": "13.3.x-scala2.12",
        "node_type_id": "i3.2xlarge",
        "num_workers": 4,
        "spark_conf": {
          "spark.sql.adaptive.enabled": "true",
          "spark.sql.adaptive.skewJoin.enabled": "true"
        },
        "aws_attributes": {
          "instance_profile_arn": "arn:aws:iam::YOUR_ACCOUNT_ID:instance-profile/databricks-s3-role",
          "availability": "ON_DEMAND"
        }
      },
      "libraries": [
        {"pypi": {"package": "delta-spark==2.4.0"}}
      ],
      "timeout_seconds": 3600,
      "max_retries": 1
    },
    {
      "task_key": "optimize_tables",
      "description": "OPTIMIZE and ZORDER Gold Delta tables",
      "depends_on": [{"task_key": "gold_aggregations"}],
      "spark_python_task": {
        "python_file": "/Workspace/log-analytics-pipeline/delta_lake/merge_scd2.py"
      },
      "new_cluster": {
        "spark_version": "13.3.x-scala2.12",
        "node_type_id": "i3.xlarge",
        "num_workers": 1,
        "aws_attributes": {
          "instance_profile_arn": "arn:aws:iam::YOUR_ACCOUNT_ID:instance-profile/databricks-s3-role"
        }
      },
      "timeout_seconds": 900,
      "max_retries": 0
    }
  ],
  "tags": {
    "project": "log-analytics-pipeline",
    "environment": "dev",
    "owner": "your-name"
  }
}
